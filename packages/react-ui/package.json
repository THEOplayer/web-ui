{
  "name": "@theoplayer/react-ui",
  "version": "1.5.0",
  "description": "React component library for the THEOplayer Web SDK",
  "main": "dist/THEOplayerReactUI.js",
  "module": "dist/THEOplayerReactUI.mjs",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/THEOplayerReactUI.mjs",
      "default": "./dist/THEOplayerReactUI.js"
    },
    "./es5": {
      "types": "./types/index.d.ts",
      "import": "./dist/THEOplayerReactUI.es5.mjs",
      "default": "./dist/THEOplayerReactUI.es5.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist/",
    "types/"
  ],
  "scripts": {
    "build": "npm run build:prod",
    "build:debug": "rollup -c && npm run build:types",
    "build:prod": "rollup -c --environment BUILD:production && npm run build:types",
    "build:types": "tsc --project . --emitDeclarationOnly",
    "watch": "rollup -c --watch",
    "test": "npm run test:typecheck",
    "test:typecheck": "tsc --project . --noEmit",
    "version": "npm run version:changelog && npm run version:deps",
    "version:changelog": "node ../../scripts/bump-changelog.mjs CHANGELOG.md && git add CHANGELOG.md",
    "version:deps": "cross-env-shell web_ui=\"@theoplayer/web-ui\" \"npm install ${web_ui}@${npm_package_version}\" && git add package.json"
  },
  "keywords": [],
  "author": "THEO Technologies",
  "license": "MIT",
  "homepage": "https://github.com/THEOplayer/web-ui/tree/main/react#readme",
  "bugs": {
    "url": "https://github.com/THEOplayer/web-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/THEOplayer/web-ui.git",
    "directory": "packages/react-ui"
  },
  "dependencies": {
    "@lit/react": "^1.0.2",
    "@theoplayer/web-ui": "^1.5.0"
  },
  "peerDependencies": {
    "@types/react": "^16.3.0 || ^17 || ^18",
    "react": "^16.3.0 || ^17 || ^18",
    "theoplayer": "^6"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-replace": "^5.0.5",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.89",
    "@swc/helpers": "^0.5.2",
    "@types/react": "^18.2.48",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^3.29.3",
    "rollup-plugin-swc3": "^0.8.2",
    "theoplayer": "^6.0.0",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.7",
    "typescript": "^5.1.6"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "chrome >= 67",
    "firefox esr"
  ]
}
