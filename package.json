{
  "name": "@theoplayer/web-ui-monorepo",
  "version": "1.5.0",
  "description": "Monorepo for the THEOplayer Open Video UI for Web",
  "private": true,
  "scripts": {
    "start": "cd docs && bundle exec jekyll serve --host localhost --force_polling",
    "format": "prettier --write .",
    "test": "npm run test:format",
    "test:format": "prettier --check .",
    "docs": "typedoc --treatWarningsAsErrors",
    "docs:watch": "typedoc --watch",
    "version": "cross-env-shell \"npm version $npm_package_version --workspaces --no-git-tag-version && git add packages/*/package.json\""
  },
  "keywords": [],
  "author": "THEO Technologies",
  "license": "MIT",
  "homepage": "https://github.com/THEOplayer/web-ui#readme",
  "bugs": "https://github.com/THEOplayer/web-ui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/THEOplayer/web-ui.git"
  },
  "workspaces": [
    "packages/web-ui",
    "packages/react-ui"
  ]
}
